#!/bin/bash

basedir="$( cd -P "$( dirname "$0" )" && pwd )"

# Set errors
set -e
set -x

# Configure directories
BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

export RVERSION="${RVERSION:-4.0.0}"

#echo "gfortran" >> "$BUILD_DIR/Aptfile"
#curl -L https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-base_${RVERSION}-1.2004.0_all.deb --output "${CACHE_DIR}/r-base_${RVERSION}-1.2004.0_all.deb"
#curl -L https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-base-core_${RVERSION}-1.2004.0_amd64.deb --output "${CACHE_DIR}/r-base-core_${RVERSION}-1.2004.0_amd64.deb"
#curl -L https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-base-dev_${RVERSION}-1.2004.0_all.deb --output "${CACHE_DIR}/r-base-dev_${RVERSION}-1.2004.0_all.deb"
#curl -L https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-recommended_${RVERSION}-1.2004.0_all.deb --output "${CACHE_DIR}/r-recommended_${RVERSION}-1.2004.0_all.deb"

#dpkg-deb -I "${CACHE_DIR}/r-base-core_${RVERSION}-1.2004.0_amd64.deb" | grep -E "Depends" | tr -d "|," | sed "s/([^)]*)/()/g" | tr -d "()" | tr " " "\n" | grep -Ev "Depends" | grep . >> "${BUILD_DIR}/Aptfile"

echo "https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-base-core_${RVERSION}-1.2004.0_amd64.deb" >> "$BUILD_DIR/Aptfile"
echo "https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-base-dev_${RVERSION}-1.2004.0_all.deb" >> "$BUILD_DIR/Aptfile"
echo "https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-recommended_${RVERSION}-1.2004.0_all.deb" >> "$BUILD_DIR/Aptfile"
echo "https://cloud.r-project.org/bin/linux/ubuntu/focal-cran40/r-base_${RVERSION}-1.2004.0_all.deb" >> "$BUILD_DIR/Aptfile"


apt_deps_buildpack_dir=$(mktemp apt_buildpack_XXXX)

# only the name is interesting, deleting the temp empty file
rm "$apt_deps_buildpack_dir"

APT_BUILDPACK_URL="${APT_BUILDPACK_URL:-https://github.com/Scalingo/apt-buildpack}"
git clone --depth=1 "$APT_BUILDPACK_URL" "$apt_deps_buildpack_dir"

"${apt_deps_buildpack_dir}/bin/compile" "$BUILD_DIR" "$CACHE_DIR" "$ENV_DIR"

rm -r "$apt_deps_buildpack_dir"

#export PATH="${HOME}/.apt/usr:${PATH}"
export PATH="${HOME}/.apt/usr/bin:${PATH}"

ln -fs /usr/lib/R ${HOME}/.apt/usr/lib/R

export R_HOME="${HOME}/.apt/usr/lib/R"

ln -fs ${HOME}/.apt/usr/lib/R/etc/Makeconf ${HOME}/.apt/etc/R/Makeconf
ln -fs ${HOME}/.apt/usr/lib/R/etc/Renviron ${HOME}/.apt/etc/R/Renviron
ln -fs ${HOME}/.apt/usr/lib/R/etc/Renviron.site ${HOME}/.apt/etc/R/Renviron.site
ln -fs ${HOME}/.apt/usr/lib/R/etc/Rprofile.site ${HOME}/.apt/etc/R/Rprofile.site
ln -fs ${HOME}/.apt/usr/lib/R/etc/ldpaths ${HOME}/.apt/etc/R/ldpaths
ln -fs ${HOME}/.apt/usr/lib/R/etc/repositories ${HOME}/.apt/etc/R/repositories

curl -L https://cran.r-project.org/src/contrib/shiny_1.7.3.tar.gz --output ${CACHE_DIR}/shiny_1.7.3.tar.gz
R CMD INSTALL ${CACHE_DIR}/shiny_1.7.3.tar.gz

#dpkg -i "${CACHE_DIR}/r-base-core_${RVERSION}-1.2004.0_amd64.deb"
#dpkg -i "${CACHE_DIR}/r-recommended_${RVERSION}-1.2004.0_all.deb"
#dpkg -i "${CACHE_DIR}/r-base-dev_${RVERSION}-1.2004.0_all.deb"
#dpkg -i "${CACHE_DIR}/r-base_${RVERSION}-1.2004.0_all.deb"

#curl -L https://cran.r-project.org/src/base/R-4/R-4.0.0.tar.gz --output "${CACHE_DIR}/R-4.0.0.tar.gz"
#cd "${CACHE_DIR}"
#tar -xvzf ./R-4.0.0.tar.gz
#cd R-4.0.0
#./configure --prefix=/app/R-4.0.0 --enable-java=no --with-recommended-packages=no --without-lapack
#make
#make install
#cd /app
#ln -sfn /app/R-4.0.0 /app/R

#export PATH="/app/R/bin:${PATH}"

